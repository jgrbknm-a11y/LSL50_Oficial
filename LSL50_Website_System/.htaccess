<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    # Front controller unificado — mismas rutas limpias que php -S + router.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ router.php [L]
</IfModule>

# Bloquear .env y otros sensibles (muy importante hoy)
<FilesMatch "^(\.env|\.env\..*|composer\.(json|lock)|artisan|\.git|\.gitignore|readme\.md|README\.md)$">
  Require all denied
</FilesMatch>

# Bloquear data/ (SQLite, .env local, backups)
<IfModule mod_authz_core.c>
  <DirectoryMatch "(^|/)data(/|$)">
    Require all denied
  </DirectoryMatch>
</IfModule>