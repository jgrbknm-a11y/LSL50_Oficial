# LSL50 local secrets — copy to .env at the project root (outside the web docroot).
# Never commit the real .env file.

# Admin panel (/admin) — password is hashed into DB on first boot.
LSL50_ADMIN_EMAIL=admin@lsl50.local
LSL50_ADMIN_PASSWORD=change-me-now

# Optional: override scorer tablet PIN (otherwise uses app_settings / default).
# LSL50_SCORER_PIN=

# --- Database (default: sqlite for local dev) ---
# DB_DRIVER=sqlite
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=lsl50
# DB_USER=lsl50
# DB_PASS=lsl50
# DB_ROOT_USER=root
# DB_ROOT_PASS=root

# Optional: OpenAI for AI game notes
# OPENAI_API_KEY=
